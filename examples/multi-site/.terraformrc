# Terraform CLI config for multi-site deployments
#
# plugin_cache_dir — avoid re-downloading the provider on every `terraform init`
plugin_cache_dir = "$HOME/.terraform.d/plugin-cache"

# provider_installation — used for airgapped sites where registry.terraform.io
# is unreachable. Copy the provider binary into /usr/local/lib/tf-plugins/ on
# the bastion (or inside the ocp-toolbox image) and Terraform will use it
# without contacting the internet.
#
# For connected sites, comment out this block and Terraform will pull from the
# public registry as normal.
#
# provider_installation {
#   filesystem_mirror {
#     path    = "/usr/local/lib/tf-plugins"
#     include = ["registry.terraform.io/gabrielborcean/openshift"]
#   }
#   direct {
#     exclude = ["registry.terraform.io/gabrielborcean/openshift"]
#   }
# }
